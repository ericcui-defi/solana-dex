# Solana RPC endpoint used by the browser client.
# If unset, falls back to public devnet (https://api.devnet.solana.com), which
# is heavily rate-limited and unsuitable for production.
#
# For Vercel: set this in Project → Settings → Environment Variables.
# Recommended providers: Helius, Triton, QuickNode.
VITE_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_API_KEY_HERE
